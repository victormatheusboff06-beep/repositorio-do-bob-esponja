<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Kalix CO</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        color: #333;
        min-height: 100vh;
    }

    /* Navegação */
    nav {
        background: linear-gradient(90deg, #4f46e5, #9333ea);
        padding: 0 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    nav li {
        position: relative;
    }

    nav a {
        display: block;
        padding: 16px 20px;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        font-weight: 500;
        font-size: 15px;
    }

    nav a:hover {
        background: rgba(255,255,255,0.25);
        transform: translateY(-2px);
    }

    /* Submenu */
    nav ul ul {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background: white;
        min-width: 180px;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    nav ul ul li a {
        color: #4f46e5;
        padding: 12px 16px;
    }

    nav ul ul li a:hover {
        background: #f0f0ff;
        color: #9333ea;
    }

    nav li:hover > ul {
        display: block;
    }

    /* Main content */
    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    section {
        background: white;
        border-radius: 12px;
        padding: 40px;
        margin-bottom: 40px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        animation: slideIn 0.6s ease;
        scroll-margin-top: 80px;
    }

    .categoria-bloco {
        background: #f8f7ff;
        border: 1px solid #e6e4ff;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 20px;
    }

    .categoria-bloco h3 {
        margin-top: 0;
        font-size: 1.4em;
        color: #4f46e5;
    }

    .categoria-bloco p,
    .categoria-bloco ul {
        margin: 0;
    }

    .categoria-bloco ul li {
        padding-left: 25px;
        position: relative;
    }

    .categoria-bloco ul li:before {
        content: "•";
        position: absolute;
        left: 0;
        color: #9333ea;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    h1 {
        color: #4f46e5;
        font-size: 2.5em;
        margin-bottom: 15px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
    }

    h2 {
        color: #9333ea;
        font-size: 2em;
        margin-bottom: 20px;
        border-bottom: 3px solid #4f46e5;
        padding-bottom: 10px;
    }

    h3 {
        color: #4f46e5;
        font-size: 1.3em;
        margin-top: 20px;
        margin-bottom: 12px;
    }

    p {
        color: #555;
        font-size: 1.05em;
        line-height: 1.8;
        margin-bottom: 15px;
    }

    ul {
        list-style: none;
        padding-left: 0;
    }

    section ul li {
        color: #555;
        padding: 10px 0;
        padding-left: 30px;
        position: relative;
        font-size: 1.05em;
        line-height: 1.6;
    }

    section ul li:before {
        content: "✨";
        position: absolute;
        left: 0;
        color: #9333ea;
    }

    /* Formulários */
    form {
        display: flex;
        flex-direction: column;
        max-width: 500px;
    }

    form div {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

    label {
        font-weight: 600;
        color: #4f46e5;
        margin-bottom: 8px;
        font-size: 1em;
    }

    input[type="text"],
    input[type="email"],
    input[type="password"],
    input[type="tel"],
    input[type="checkbox"] {
        padding: 12px 15px;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        font-size: 1em;
        transition: all 0.3s ease;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    input[type="text"]:focus,
    input[type="email"]:focus,
    input[type="password"]:focus,
    input[type="tel"]:focus {
        outline: none;
        border-color: #9333ea;
        box-shadow: 0 0 10px rgba(147, 51, 234, 0.3);
    }

    button {
        padding: 14px 30px;
        background: linear-gradient(90deg, #4f46e5, #9333ea);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.05em;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

    button:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.4);
    }

    button:active {
        transform: translateY(-1px);
    }

    a {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    a:hover {
        color: #9333ea;
        text-decoration: underline;
    }

    /* Checkbox customizado */
    input[type="checkbox"] {
        width: 20px;
        height: 20px;
        cursor: pointer;
        margin-right: 10px;
    }

    form div:has(input[type="checkbox"]) {
        flex-direction: row;
        align-items: center;
        margin-bottom: 20px;
    }

    form div:has(input[type="checkbox"]) label {
        margin-bottom: 0;
    }

    /* Painel de Contas no Canto */
    #contas-painel {
        position: fixed;
        right: 20px;
        top: 100px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
        padding: 20px;
        width: 300px;
        max-height: 500px;
        overflow-y: auto;
        z-index: 99;
        border-left: 5px solid #9333ea;
    }

    #contas-painel h3 {
        color: #9333ea;
        margin-top: 0;
        font-size: 1.2em;
        text-align: center;
    }

    .conta-item {
        background: linear-gradient(135deg, #f0f0ff, #fff);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 12px;
        border-left: 4px solid #4f46e5;
        font-size: 0.95em;
    }

    .conta-item strong {
        color: #4f46e5;
        display: block;
        margin-bottom: 5px;
    }

    .conta-item .id-usuario {
        color: #9333ea;
        font-weight: 700;
        font-size: 1.1em;
    }

    .conta-item .email-usuario {
        color: #666;
        font-size: 0.9em;
        word-break: break-all;
    }

    .conta-item .conta-categoria {
        border-top: 1px dashed #ddd;
        padding-top: 10px;
        margin-top: 10px;
    }

    .conta-item .conta-categoria strong {
        display: block;
        margin-bottom: 6px;
        color: #9333ea;
        font-size: 0.95em;
    }

    .conta-item .conta-categoria span {
        display: block;
        margin-bottom: 4px;
        color: #555;
        font-size: 0.92em;
    }

    /* Responsivo */
    @media (max-width: 768px) {
        #contas-painel {
            right: 10px;
            width: 250px;
            max-height: 400px;
        }
    }

</style>
</head>

<body>

<!-- Painel de Contas no Canto -->
<div id="contas-painel">
    <h3>📋 Contas Criadas</h3>
    <div id="lista-contas"></div>
</div>

<nav>
    <ul>
        <li><a href="#inicio">🏠 Início</a></li>

        <li>
            <a href="#">🛍️ Produtos</a>
            <ul>
                <li><a href="#produtos">Eletrônicos</a></li>
                <li><a href="#produtos">Roupas</a></li>
                <li><a href="#produtos">Acessórios</a></li>
            </ul>
        </li>

        <li>
            <a href="#">⚙️ Serviços</a>
            <ul>
                <li><a href="#servicos">Consultoria</a></li>
                <li><a href="#servicos">Suporte</a></li>
            </ul>
        </li>

        <li><a href="#sobre">ℹ️ Sobre</a></li>
        <li><a href="#contato">📞 Contato</a></li>
        <li><a href="#login">🔓 Login</a></li>
        <li><a href="#registro">📝 Registro</a></li>
    </ul>
</nav>

<main>
    <!-- Seção Início -->
    <section id="inicio">
        <h1>Bem-vindo à Kalix CO</h1>
        <p>Sua plataforma de confiança para produtos e serviços de qualidade.</p>
    </section>

    <!-- Seção Produtos -->
    <section id="produtos">
        <h2>Nossos Produtos</h2>
        <div class="categoria-bloco">
            <h3>Eletrônicos</h3>
            <ul>
                <li>Smartphone - R$ 1.500,00</li>
                <li>Notebook - R$ 3.500,00</li>
                <li>Tablet - R$ 1.200,00</li>
            </ul>
        </div>
        <div class="categoria-bloco">
            <h3>Roupas</h3>
            <ul>
                <li>Camiseta - R$ 49,90</li>
                <li>Calça - R$ 89,90</li>
                <li>Jaqueta - R$ 150,00</li>
            </ul>
        </div>
        <div class="categoria-bloco">
            <h3>Acessórios</h3>
            <ul>
                <li>Relógio - R$ 200,00</li>
                <li>Mochila - R$ 120,00</li>
                <li>Óculos - R$ 180,00</li>
            </ul>
        </div>
    </section>

    <!-- Seção Serviços -->
    <section id="servicos">
        <h2>Nossos Serviços</h2>
        <div class="categoria-bloco">
            <h3>Consultoria</h3>
            <p>Orientação especializada para suas necessidades</p>
        </div>
        <div class="categoria-bloco">
            <h3>Suporte</h3>
            <p>Atendimento 24/7 para resolver seus problemas</p>
        </div>
    </section>

    <!-- Seção Sobre -->
    <section id="sobre">
        <h2>Sobre Nós</h2>
        <p>A Kalix CO é uma empresa dedicada a oferecer productos e serviços de alta qualidade.</p>
        <p>Com mais de 10 anos de experiência, conquistamos a confiança de milhares de clientes.</p>
    </section>

    <!-- Seção Contato -->
    <section id="contato">
        <h2>Entre em Contato</h2>
        <p>Email: contato@kalixco.com</p>
        <p>Telefone: (11) 3000-0000</p>
        <p>Endereço: São Paulo, SP</p>
    </section>

    <!-- Seção Login -->
    <section id="login">
        <h2>Login</h2>
        <form method="POST" action="/login">
            <div>
                <label for="email-login">Email:</label>
                <input type="email" id="email-login" name="email" required>
            </div>
            <div>
                <label for="senha-login">Senha:</label>
                <input type="password" id="senha-login" name="senha" required>
            </div>
            <button type="submit">Entrar</button>
            <p>Não tem conta? <a href="#registro">Crie uma aqui</a></p>
        </form>
    </section>

    <!-- Seção Registro -->
    <section id="registro">
        <h2>Criar Conta</h2>
        <form method="POST" action="/registro">
            <div>
                <label for="nome-registro">Nome Completo:</label>
                <input type="text" id="nome-registro" name="nome" required>
            </div>
            <div>
                <label for="email-registro">Email:</label>
                <input type="email" id="email-registro" name="email" required>
            </div>
            <div>
                <label for="telefone-registro">Telefone:</label>
                <input type="tel" id="telefone-registro" name="telefone" required>
            </div>
            <div>
                <label for="senha-registro">Senha:</label>
                <input type="password" id="senha-registro" name="senha" required>
            </div>
            <div>
                <label for="confirmar-senha">Confirmar Senha:</label>
                <input type="password" id="confirmar-senha" name="confirmar-senha" required>
            </div>
            <div>
                <label for="termos">
                    <input type="checkbox" id="termos" name="termos" required>
                    Concordo com os termos e condições
                </label>
            </div>
            <button type="submit">Criar Conta</button>
            <p>Já tem conta? <a href="#login">Faça login aqui</a></p>
        </form>
    </section>
</main>

<script>
    // Sistema de Gerenciamento de Contas
    class GerenciadorContas {
        constructor() {
            this.contas = this.carregarContas();
            this.idExistentes = new Set(this.contas.map(c => c.id));
        }

        // Gerar ID único aleatório
        gerarIDUnico() {
            let id;
            do {
                id = Math.floor(Math.random() * 1000000) + 1;
            } while (this.idExistentes.has(id));
            return id;
        }

        // Criar nova conta
        criarConta(nome, email, telefone, senha) {
            const novaContaID = this.gerarIDUnico();
            const novaConta = {
                id: novaContaID,
                nome: nome,
                email: email,
                telefone: telefone,
                senha: senha,
                dataCriacao: new Date().toLocaleDateString('pt-BR')
            };

            this.contas.push(novaConta);
            this.idExistentes.add(novaContaID);
            this.salvarContas();
            this.exibirContas();
            
            return novaContaID;
        }

        // Salvar contas no localStorage
        salvarContas() {
            localStorage.setItem('contas', JSON.stringify(this.contas));
        }

        // Carregar contas do localStorage
        carregarContas() {
            const contasArmazenadas = localStorage.getItem('contas');
            return contasArmazenadas ? JSON.parse(contasArmazenadas) : [];
        }

        // Exibir contas no painel
        exibirContas() {
            const listaContas = document.getElementById('lista-contas');
            listaContas.innerHTML = '';

            if (this.contas.length === 0) {
                listaContas.innerHTML = '<p style="color: #999; text-align: center;">Nenhuma conta criada ainda</p>';
                return;
            }

            this.contas.forEach(conta => {
                const contaDiv = document.createElement('div');
                contaDiv.className = 'conta-item';
                contaDiv.innerHTML = `
                    <strong>👤 ${conta.nome}</strong>
                    <div class="id-usuario">ID: #${conta.id}</div>
                    <div class="conta-categoria">
                        <strong>Dados de contato</strong>
                        <span>📧 ${conta.email}</span>
                        <span>📞 ${conta.telefone}</span>
                    </div>
                    <div class="conta-categoria">
                        <strong>Detalhes da conta</strong>
                        <span>Criada em: ${conta.dataCriacao}</span>
                        <span>Senha cadastrada: ●●●●●●●●</span>
                    </div>
                `;
                listaContas.appendChild(contaDiv);
            });
        }
    }

    // Inicializar gerenciador
    const gerenciador = new GerenciadorContas();
    gerenciador.exibirContas();

    // Interceptar formulário de registro
    document.querySelector('form[action="/registro"]').addEventListener('submit', function(e) {
        e.preventDefault();

        // Obter dados do formulário
        const nome = document.getElementById('nome-registro').value;
        const email = document.getElementById('email-registro').value;
        const telefone = document.getElementById('telefone-registro').value;
        const senha = document.getElementById('senha-registro').value;
        const confirmarSenha = document.getElementById('confirmar-senha').value;

        // Validações
        if (!nome || !email || !telefone || !senha || !confirmarSenha) {
            alert('❌ Por favor, preencha todos os campos!');
            return;
        }

        if (senha !== confirmarSenha) {
            alert('❌ As senhas não conferem!');
            return;
        }

        if (senha.length < 6) {
            alert('❌ A senha deve ter pelo menos 6 caracteres!');
            return;
        }

        // Verificar se email já existe
        const emailExiste = gerenciador.contas.some(c => c.email === email);
        if (emailExiste) {
            alert('❌ Este email já está registrado!');
            return;
        }

        // Criar conta
        const novoID = gerenciador.criarConta(nome, email, telefone, senha);
        
        // Limpar formulário
        this.reset();

        // Mostrar mensagem de sucesso
        alert(`✅ Conta criada com sucesso!\n\n🎉 Seu ID é: #${novoID}\n\nGuarde este número com você!`);

        // Rolar para o painel de contas
        document.getElementById('contas-painel').scrollIntoView({ behavior: 'smooth' });
    });
</script>

</body>
</html>
